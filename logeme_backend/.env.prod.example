DJANGO_SECRET_KEY=CHANGE_ME_LONG_RANDOM
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=api.logeme.tg

SQLITE_NAME=db.sqlite3

APP_LINK_BASE=logeme://auth
FRONTEND_BASE_URL=https://logeme.app

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@logeme.app
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=YOUR_APP_PASSWORD
EMAIL_USE_TLS=1

CORS_ALLOW_ALL_ORIGINS=0
CORS_ALLOWED_ORIGINS=https://logeme.app
CSRF_TRUSTED_ORIGINS=https://api.logeme.tg

SECURE_SSL_REDIRECT=1
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
